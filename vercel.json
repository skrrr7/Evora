{
    "version": 2,
    "buildCommand": "npm run build",
    "outputDirectory": "frontend/dist",
    "builds": [
      {
        "src": "backend/src/server.js",
        "use": "@vercel/node"
      }
    ],
    "rewrites": [
      { "source": "/api/(.*)", "destination": "/backend/src/server.js?path=$1" },
      { "source": "/(.*)", "destination": "/index.html" }
    ]
  }